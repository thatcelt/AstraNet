# Build stage
FROM golang:1.26-alpine AS builder

RUN apk add --no-cache gcc musl-dev sqlite-dev

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=1 GOOS=linux go build -a -ldflags '-linkmode external -extldflags "-static"' -o api ./cmd/api

# Runtime stage
FROM alpine:latest

RUN apk add --no-cache ca-certificates tzdata sqlite ffmpeg

WORKDIR /app

COPY --from=builder /app/api .

RUN mkdir -p /app/data /app/logs /app/config

EXPOSE 8080

CMD ["./api"]
