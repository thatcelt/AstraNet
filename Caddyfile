# Global options
{
	servers {
		max_header_size 16384
	}
}

# API server
api.astranetapp.com {
	import /etc/caddy/tor_block.caddy

	request_body {
		max_size 50MB
	}

	reverse_proxy api:8080

	encode gzip

	header {
		-Server
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-XSS-Protection "1; mode=block"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Content-Security-Policy "default-src 'none'; frame-ancestors 'none'"
	}
}

# Media server
media.astranetapp.com {
	import /etc/caddy/tor_block.caddy

	request_body {
		max_size 50MB
	}

	reverse_proxy media:8081

	header {
		-Server
		Cache-Control "public, max-age=31536000, immutable"
		X-Content-Type-Options nosniff
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		Content-Security-Policy "default-src 'none'; media-src 'self'; img-src 'self'"
	}
}

# Web client
testsite.astranetapp.com {
	import /etc/caddy/tor_block.caddy

	root * /srv/web
	file_server
	encode gzip
	try_files {path} /index.html

	header {
		-Server
		X-Content-Type-Options nosniff
		Cross-Origin-Opener-Policy same-origin
		Cross-Origin-Embedder-Policy require-corp
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}
	header /index.html Cache-Control "no-cache, no-store, must-revalidate"
	header /flutter_bootstrap.js Cache-Control "no-cache, no-store, must-revalidate"
	header /flutter_service_worker.js Cache-Control "no-cache, no-store, must-revalidate"
	header /main.dart.js Cache-Control "no-cache, no-store, must-revalidate"
	header /firebase-messaging-sw.js Cache-Control "no-cache, no-store, must-revalidate"
	header /version.json Cache-Control "no-cache, no-store, must-revalidate"
}
